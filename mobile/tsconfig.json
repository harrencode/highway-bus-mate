{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "experimentalDecorators": true,
    "target": "esnext",
    "module": "esnext",
    "lib": ["ESNext"],
    "allowJs": true,
    "jsx": "react-native",
    "noEmit": true,
    "isolatedModules": false,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitThis": true,
    "ignoreDeprecations": "5.0",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": "src",
    "paths": {
      "@app": ["app"],
      "@app/*": ["app/*"],
      "@assets": ["assets"],
      "@assets/*": ["assets/*"],
      "@atomic": ["atomic"],
      "@atomic/*": ["atomic/*"],
      "@atomic-samples": ["atomic-samples"],
      "@atomic-samples/*": ["atomic-samples/*"]
    }
  },
  "include": ["src/**/*", "src/declarations.d.ts", "styled.d.ts", "images.d.ts"],
  "exclude": ["node_modules", "babel.config.js", "metro.config.js", "jest.config.js"]
}
