{
  "name": "highway-bus-mate-mobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android:dev": "ENVFILE=env/dev.env react-native run-android",
    "android:staging": "ENVFILE=env/stg.env react-native run-android --variant=staging",
    "android:prod": "ENVFILE=env/prod.env react-native run-android --variant=release",
    "ios:dev": "ENVFILE=env/dev.env react-native run-ios",
    "ios:staging": "ENVFILE=env/stg.env react-native run-ios --configuration Staging",
    "ios:prod": "ENVFILE=env/prod.env react-native run-ios --configuration Release",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "validate:atomic": "node scripts/validate-atomic-structure.js",
    "start": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start:lan": "expo start --lan",
    "start:clear": "expo start --clear",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:android:debug": "cd android && gradlew assembleDebug",
    "build:android:release": "cd android && gradlew assembleRelease",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-s3": "^3.932.0",
    "@gorhom/portal": "^1.0.14",
    "@notifee/react-native": "^9.1.8",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-native/new-app-screen": "0.80.0",
    "@react-navigation/bottom-tabs": "^7.4.7",
    "@react-navigation/native-stack": "^7.3.26",
    "@stripe/stripe-react-native": "0.50.3",
    "@tanstack/react-query": "^5.90.5",
    "axios": "^1.13.1",
    "babel-preset-expo": "^54.0.10",
    "buffer": "^6.0.3",
    "cpf-check": "^3.0.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "expo": "^54.0.34",
    "jwt-decode": "^4.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-animatable": "^1.4.0",
    "react-native-aws3": "^0.0.9",
    "react-native-calendars": "^1.1313.0",
    "react-native-config": "^1.6.1",
    "react-native-fs": "^2.20.0",
    "react-native-google-places-autocomplete": "^2.5.7",
    "react-native-heroicons": "^4.0.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-indicators": "^0.17.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-keychain": "^10.0.0",
    "react-native-maps": "1.20.1",
    "react-native-mask-input": "^1.2.3",
    "react-native-screens": "^4.16.0",
    "reflect-metadata": "^0.2.2",
    "rn-crypto-polyfill": "^1.0.4",
    "stripe": "^20.0.0",
    "styled-components": "^6.1.19",
    "typedi": "^0.10.0",
    "types": "^0.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@gorhom/bottom-sheet": "^5.1.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/cli": "19.0.0",
    "@react-native-community/cli-platform-android": "19.0.0",
    "@react-native-community/cli-platform-ios": "19.0.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-native/babel-preset": "0.80.0",
    "@react-native/eslint-config": "0.80.0",
    "@react-native/metro-config": "0.80.0",
    "@react-native/typescript-config": "^0.80.0",
    "@types/jest": "^29.5.13",
    "@types/jwt-decode": "^2.2.1",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-loader": "^8.4.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-native": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "lint-staged": "^16.2.4",
    "prettier": "2.8.8",
    "react-dom": "^19.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
