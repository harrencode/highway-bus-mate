# Environment
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=change-me-in-production

# CORS (comma-separated origins)
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:8000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hbm_db
DB_USER=hbm_user
DB_PASSWORD=secure_password_123

# Test database — fully independent credentials, never touches auth_db
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=3306
TEST_DB_NAME=hbm_test_db
TEST_DB_USER=hbm_user
TEST_DB_PASSWORD=secure_password_123

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
